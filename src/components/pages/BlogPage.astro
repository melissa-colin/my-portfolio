---
import PageLayout from '../../layouts/PageLayout.astro';
import { FiClock, FiSearch, FiArrowRight } from 'react-icons/fi';
import { getUI, getList, type Locale } from '../../lib/content';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const ui = await getUI(locale);
const b = ui.blog ?? {};
const posts = await getList('blog', locale);

// Categories with counts (first-seen order, matches reduce + Object.entries)
const categoriesObj: Record<string, number> = {};
for (const post of posts) {
  categoriesObj[post.category] = (categoriesObj[post.category] || 0) + 1;
}
const categories = Object.entries(categoriesObj).map(([name, count]) => ({ name, count }));

// Unique tags in first-seen order
const tags = [...new Set(posts.flatMap((post: any) => post.tags || []))];

const fmt = new Intl.DateTimeFormat(locale === 'fr' ? 'fr-FR' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const formatDate = (dateString: string) => fmt.format(new Date(dateString));
---

<PageLayout locale={locale} path="/blog" title={`${b.title} | Mélissa Colin`}>
  <div class="pt-24 pb-20">
    {/* Hero Section */}
    <section class="bg-gray-900 dark:bg-black py-16 relative overflow-hidden">
      <div class="absolute inset-0 bg-opacity-70">
        <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-br from-gray-900 via-transparent to-red-900/20 opacity-80"></div>
      </div>

      <div class="container mx-auto px-4 relative z-10">
        <div class="max-w-4xl mx-auto text-center">
          <h1 class="anim-title title-gradient text-4xl md:text-5xl font-bold mb-6 text-white">
            {b.title}
          </h1>

          <div class="a-bar section-bar mx-auto bg-red-500" style="animation-delay:0.25s"></div>

          <p class="a-fade mt-6 text-xl text-gray-200 max-w-3xl mx-auto" style="animation-delay:0.4s">
            {b.subtitle}
          </p>
        </div>
      </div>
    </section>
    {/* Blog Content */}
    <section class="py-20">
      <div class="container mx-auto px-4">
        <div class="flex flex-wrap" id="blog-root">
          {/* Blog Posts */}
          <div class="w-full lg:w-2/3 pr-0 lg:pr-8">
            {/* Search */}
            <div class="mb-8">
              <div class="relative">
                <FiSearch className="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400" />
                <input
                  type="text"
                  id="blog-search"
                  placeholder={b.searchPosts}
                  class="w-full pl-10 pr-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-800 dark:text-white"
                />
              </div>
            </div>
            {/* Posts */}
            <div class="space-y-10" id="blog-posts" data-stagger>
              <div id="blog-empty" class="text-center text-gray-500 dark:text-gray-400" style="display:none;">
                {b.noPostsFound || 'Aucun article trouvé.'}
              </div>
              {posts.map((post: any) => (
                <div
                  class="js-post bg-white dark:bg-gray-800 rounded-lg shadow-lg overflow-hidden transition-transform duration-200 hover:shadow-2xl hover:-translate-y-1"
                  data-search={`${post.title} ${post.excerpt} ${post.category}`.toLowerCase()}
                  data-tags={(post.tags || []).join('|')}
                >
                  <div class="md:flex">
                    <div class="md:w-1/3">
                      <div class="h-48 md:h-full">
                        <img
                          src={post.image}
                          alt={post.title}
                          class="w-full h-full object-cover"
                          width={300}
                          height={192}
                          loading="lazy"
                        />
                      </div>
                    </div>
                    <div class="md:w-2/3 p-6">
                      <div class="flex items-center mb-2">
                        <span class="text-sm bg-red-100 dark:bg-red-900/20 text-red-800 dark:text-red-300 px-2 py-1 rounded">
                          {post.category}
                        </span>
                        <div class="flex items-center text-gray-500 dark:text-gray-400 ml-3 text-sm">
                          <FiClock className="mr-1" />
                          <span>{post.readTime} {b.readTime}</span>
                        </div>
                      </div>

                      <h2 class="text-2xl font-bold mb-3 text-gray-900 dark:text-white">
                        {post.title}
                      </h2>

                      <p class="text-gray-700 dark:text-gray-300 mb-4">
                        {post.excerpt}
                      </p>

                      <div class="flex items-center justify-between mt-4">
                        <div class="text-gray-500 dark:text-gray-400 text-sm">
                          {`${b.publishedOn} ${formatDate(post.date)}`}
                        </div>

                        <a
                          href={post.link}
                          class="text-red-600 dark:text-red-500 hover:text-red-700 dark:hover:text-red-400 inline-flex items-center"
                          target="_blank"
                          rel="noopener noreferrer"
                        >
                          {b.readMore} <FiArrowRight className="ml-1" />
                        </a>
                      </div>
                      {/* Affichage des tags de l'article */}
                      {post.tags && post.tags.length > 0 && (
                        <div class="mt-4 flex flex-wrap gap-2">
                          {post.tags.map((tag: string) => (
                            <span class="px-2 py-1 bg-gray-200 dark:bg-gray-700 text-gray-800 dark:text-gray-300 rounded-full text-xs">
                              {tag}
                            </span>
                          ))}
                        </div>
                      )}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          {/* Sidebar */}
          <div class="w-full lg:w-1/3 mt-12 lg:mt-0">
            {/* Categories */}
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-6 mb-8">
              <h3 class="text-xl font-bold mb-4 text-gray-900 dark:text-white">
                {b.categories}
              </h3>
              <ul>
                {categories.map((category: any) => (
                  <li class="flex items-center justify-between mb-2">
                    <span class="text-gray-800 dark:text-gray-300">{category.name}</span>
                    <span class="bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 text-sm px-2 py-1 rounded-full">
                      {category.count}
                    </span>
                  </li>
                ))}
              </ul>
            </div>
            {/* Tags Filter */}
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-6 mb-8" id="blog-tags">
              <h3 class="text-xl font-bold mb-4 text-gray-900 dark:text-white">
                {b.popularTags}
              </h3>
              <div class="flex flex-wrap gap-2">
                {tags.map((tag: string) => (
                  <button
                    type="button"
                    data-tag={tag}
                    class="js-tag px-3 py-1 rounded-full text-sm transition-colors bg-gray-200 dark:bg-gray-700 text-gray-800 dark:text-gray-300 hover:bg-red-100 dark:hover:bg-red-900/20 hover:text-red-800 dark:hover:text-red-300"
                    data-active-class="bg-red-500 text-white"
                    data-idle-class="bg-gray-200 dark:bg-gray-700 text-gray-800 dark:text-gray-300 hover:bg-red-100 dark:hover:bg-red-900/20 hover:text-red-800 dark:hover:text-red-300"
                  >
                    {tag}
                  </button>
                ))}
                <button
                  type="button"
                  id="blog-clear-tag"
                  class="ml-2 px-2 py-1 bg-gray-300 dark:bg-gray-600 text-gray-700 dark:text-gray-200 rounded-full text-xs"
                  style="display:none;"
                >
                  {b.clearTag || 'Effacer'}
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</PageLayout>

<script is:inline>
  (function () {
    var root = document.getElementById('blog-root');
    if (!root) return;
    var search = document.getElementById('blog-search');
    var tagBtns = Array.prototype.slice.call(root.querySelectorAll('.js-tag'));
    var clearBtn = document.getElementById('blog-clear-tag');
    var posts = Array.prototype.slice.call(root.querySelectorAll('#blog-posts .js-post'));
    var empty = document.getElementById('blog-empty');
    var activeTag = null;

    function setTagClasses(el, str) { el.className = 'js-tag px-3 py-1 rounded-full text-sm transition-colors ' + str; }

    function apply() {
      var q = (search && search.value || '').toLowerCase();
      var visible = 0;
      posts.forEach(function (p) {
        var okSearch = (p.getAttribute('data-search') || '').indexOf(q) !== -1;
        var tagList = (p.getAttribute('data-tags') || '').split('|');
        var okTag = activeTag ? tagList.indexOf(activeTag) !== -1 : true;
        var show = okSearch && okTag;
        p.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (empty) empty.style.display = visible === 0 ? '' : 'none';
      tagBtns.forEach(function (b) {
        var active = b.getAttribute('data-tag') === activeTag;
        setTagClasses(b, active ? b.getAttribute('data-active-class') : b.getAttribute('data-idle-class'));
      });
      if (clearBtn) clearBtn.style.display = activeTag ? '' : 'none';
    }

    tagBtns.forEach(function (b) {
      b.addEventListener('click', function () {
        var t = b.getAttribute('data-tag');
        activeTag = t === activeTag ? null : t;
        apply();
      });
    });
    if (clearBtn) clearBtn.addEventListener('click', function () { activeTag = null; apply(); });
    if (search) search.addEventListener('input', apply);
    apply();
  })();
</script>
