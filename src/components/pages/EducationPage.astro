---
import PageLayout from '../../layouts/PageLayout.astro';
import { FiAward, FiCalendar, FiMapPin, FiBookOpen } from 'react-icons/fi';
import { getUI, getList, type Locale } from '../../lib/content';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const ui = await getUI(locale);
const educationData = await getList('education', locale);
---

<PageLayout locale={locale} path="/education" title={`${ui.nav.education} | ${ui.home.heroTitle}`}>
  <div class="pt-24 pb-20">
    {/* Hero Section */}
    <section class="bg-gray-900 dark:bg-black py-16 relative overflow-hidden">
      <div class="absolute inset-0 bg-opacity-70">
        <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-br from-gray-900 via-transparent to-red-900/20 opacity-80"></div>
      </div>
      <div class="container mx-auto px-4 relative z-10">
        <div class="max-w-4xl mx-auto text-center">
          <h1 class="text-4xl md:text-5xl font-bold mb-6 text-white">{ui.nav.education}</h1>
          <div class="section-bar mx-auto bg-red-500"></div>
          <p class="mt-6 text-xl text-gray-200 max-w-3xl mx-auto">{ui.education.subtitle}</p>
        </div>
      </div>
    </section>

    {/* Main Content */}
    <section class="py-20 education-page">
      <div class="container mx-auto px-4">
        {educationData.length === 0 ? (
          <div class="text-center text-gray-500 py-32">
            <p>{locale === 'fr' ? 'Aucune formation à afficher.' : 'No education to display.'}</p>
          </div>
        ) : (
          <div class="space-y-12 max-w-4xl mx-auto" data-stagger>
            {educationData.map((edu: any) => (
              <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-6 md:p-8 border border-gray-200 dark:border-gray-800 hover:border-red-900/50 transition-colors">
                <div class="flex flex-col md:flex-row md:items-start gap-6">
                  <div class="flex-shrink-0">
                    <div class="w-14 h-14 flex items-center justify-center rounded-full bg-red-900/30 text-red-500">
                      <FiAward size={24} />
                    </div>
                  </div>
                  <div class="flex-1">
                    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-2 mb-2">
                      <h3 class="text-2xl font-bold text-gray-900 dark:text-white">{edu.degree}</h3>
                      <div class="flex items-center text-sm text-red-500 font-semibold">
                        <FiCalendar className="mr-1" />
                        <span>{edu.period}</span>
                      </div>
                    </div>
                    <div class="text-lg text-red-400 mb-2">{edu.specialization}</div>
                    {/* GPA & Rank */}
                    {(edu.gpa || edu.rank) && (
                      <div class="flex flex-wrap items-center gap-4 mb-2">
                        {edu.gpa && (
                          <span class="inline-flex items-center text-sm bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200 px-2 py-1 rounded">
                            <span class="font-semibold mr-1">{ui.education.gpa}:</span>
                            {edu.gpa}
                          </span>
                        )}
                        {edu.rank && (
                          <span class="inline-flex items-center text-sm bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200 px-2 py-1 rounded">
                            <span class="font-semibold mr-1">{ui.education.rank}:</span>
                            {edu.rank}
                          </span>
                        )}
                      </div>
                    )}
                    <div class="flex flex-col md:flex-row md:items-center gap-2 mb-6">
                      <div class="flex items-center text-gray-700 dark:text-gray-300">
                        <FiBookOpen className="mr-1" />
                        <span>{edu.institution}</span>
                      </div>
                      <span class="hidden md:block text-gray-400 dark:text-gray-600">•</span>
                      <div class="flex items-center text-gray-500 dark:text-gray-400 text-sm">
                        <FiMapPin className="mr-1" />
                        <span>{edu.location}</span>
                      </div>
                    </div>
                    <p class="text-gray-700 dark:text-gray-300 mb-6">{edu.description}</p>
                    {edu.achievements && edu.achievements.length > 0 && (
                      <div class="space-y-2">
                        <h4 class="text-gray-900 dark:text-white font-semibold mb-2">
                          {locale === 'fr' ? 'Réalisations & Activités' : 'Achievements & Activities'}
                        </h4>
                        <ul class="list-disc list-inside text-gray-700 dark:text-gray-400 space-y-1 ml-2">
                          {edu.achievements.map((achievement: any) => (
                            <li set:html={achievement} />
                          ))}
                        </ul>
                      </div>
                    )}
                  </div>
                </div>
              </div>
            ))}
          </div>
        )}

        {educationData.length > 0 && (
          <div class="text-center mt-16">
            <p class="text-gray-400">{ui.education.footer}</p>
          </div>
        )}
      </div>
    </section>
  </div>
</PageLayout>
