---
import PageLayout from '../../layouts/PageLayout.astro';
import { FiGithub, FiExternalLink, FiFilter } from 'react-icons/fi';
import { getUI, getList, type Locale } from '../../lib/content';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const ui = await getUI(locale);
const p = ui.projects ?? {};
const projects = await getList('projects', locale);

// Unique categories in first-seen order (matches Array.from(new Set(...)))
const categories = [...new Set(projects.map((x: any) => x.category))];
const demoLabel = (demo: string) =>
  demo && demo.includes('hal.science') ? 'Publication' : p.viewLive;
---

<PageLayout locale={locale} path="/projects" title={`${p.title} | Mélissa Colin`}>
  <div class="pt-24 pb-20">
    {/* Hero */}
    <section class="bg-gray-900 dark:bg-black py-16 relative overflow-hidden">
      <div class="absolute inset-0 bg-opacity-70">
        <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-br from-gray-900 via-transparent to-red-900/20 opacity-80"></div>
      </div>
      <div class="container mx-auto px-4 relative z-10">
        <div class="max-w-4xl mx-auto text-center">
          <h1 class="anim-title text-4xl md:text-5xl font-bold mb-6 text-white">{p.title}</h1>
          <div class="a-bar section-bar mx-auto bg-red-500" style="animation-delay:0.25s"></div>
          <p class="a-fade mt-6 text-xl text-gray-200 max-w-3xl mx-auto" style="animation-delay:0.4s">{p.subtitle}</p>
        </div>
      </div>
    </section>

    {/* Grid */}
    <section class="py-20">
      <div class="container mx-auto px-4">
        {/* Filters */}
        <div class="max-w-6xl mx-auto mb-12" id="projects-filter">
          <div class="flex flex-wrap items-center justify-between gap-4 mb-8">
            <div class="flex items-center">
              <FiFilter className="text-red-600 dark:text-red-500 mr-2" />
              <h2 class="text-xl font-bold text-gray-900 dark:text-white">{p.filter}</h2>
            </div>
            <div class="flex flex-wrap gap-2">
              <button
                data-cat="all"
                class="js-cat px-4 py-2 rounded-md bg-red-600 text-white"
                data-active-class="bg-red-600 text-white"
                data-idle-class="bg-gray-200 dark:bg-gray-700 text-gray-800 dark:text-white hover:bg-gray-300 dark:hover:bg-gray-600"
              >{p.allCategories}</button>
              {categories.map((cat: string) => (
                <button
                  data-cat={cat}
                  class="js-cat px-4 py-2 rounded-md bg-gray-200 dark:bg-gray-700 text-gray-800 dark:text-white hover:bg-gray-300 dark:hover:bg-gray-600"
                  data-active-class="bg-red-600 text-white"
                  data-idle-class="bg-gray-200 dark:bg-gray-700 text-gray-800 dark:text-white hover:bg-gray-300 dark:hover:bg-gray-600"
                >{cat}</button>
              ))}
            </div>
          </div>
          <div class="w-full">
            <input
              type="text"
              id="projects-search"
              placeholder={p.search}
              class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-800 dark:text-white"
            />
          </div>
        </div>

        {/* Cards */}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto" id="projects-grid" data-stagger>
          {projects.map((project: any) => (
            <div
              class="js-project bg-white dark:bg-gray-800 rounded-lg shadow-lg overflow-hidden flex flex-col h-full transition-all duration-200 hover:-translate-y-1 hover:shadow-xl"
              data-category={project.category}
              data-search={`${project.title} ${project.description}`.toLowerCase()}
            >
              <div class="h-48 overflow-hidden">
                <img
                  src={project.image}
                  alt={project.title}
                  class="w-full h-full object-cover transition-transform duration-300 hover:scale-105"
                  width={400}
                  height={192}
                  loading="lazy"
                />
              </div>
              <div class="p-6 flex-grow">
                <h3 class="text-xl font-bold mb-2 text-gray-900 dark:text-white">{project.title}</h3>
                <p class="text-gray-700 dark:text-gray-300 mb-4">{project.description}</p>
                <div class="flex flex-wrap gap-2 mb-4">
                  {project.technologies.map((tech: string) => (
                    <span class="px-2 py-1 text-xs bg-red-100 dark:bg-red-900/20 rounded text-red-800 dark:text-red-300">{tech}</span>
                  ))}
                </div>
              </div>
              <div class="p-4 border-t border-gray-200 dark:border-gray-700 mt-auto flex justify-between items-center">
                <a href={project.github ?? undefined} target="_blank" rel="noopener noreferrer" class="text-gray-700 dark:text-gray-300 hover:text-red-600 dark:hover:text-red-500 flex items-center">
                  <FiGithub className="mr-1" /><span>GitHub</span>
                </a>
                {project.demo && (
                  <a href={project.demo} target="_blank" rel="noopener noreferrer" class="text-red-600 dark:text-red-500 hover:text-red-700 dark:hover:text-red-400 flex items-center">
                    <FiExternalLink className="mr-1" /><span>{demoLabel(project.demo)}</span>
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>
</PageLayout>

<script is:inline>
  (function () {
    var root = document.getElementById('projects-filter');
    if (!root) return;
    var btns = Array.prototype.slice.call(root.querySelectorAll('.js-cat'));
    var search = document.getElementById('projects-search');
    var cards = Array.prototype.slice.call(document.querySelectorAll('#projects-grid .js-project'));
    var selected = 'all';

    function setClasses(el, str) { el.className = 'js-cat px-4 py-2 rounded-md ' + str; }
    function apply() {
      var q = (search && search.value || '').toLowerCase();
      cards.forEach(function (c) {
        var okCat = selected === 'all' || c.getAttribute('data-category') === selected;
        var okSearch = (c.getAttribute('data-search') || '').indexOf(q) !== -1;
        c.style.display = okCat && okSearch ? '' : 'none';
      });
      btns.forEach(function (b) {
        var active = b.getAttribute('data-cat') === selected;
        setClasses(b, active ? b.getAttribute('data-active-class') : b.getAttribute('data-idle-class'));
      });
    }
    btns.forEach(function (b) {
      b.addEventListener('click', function () { selected = b.getAttribute('data-cat'); apply(); });
    });
    if (search) search.addEventListener('input', apply);
    apply();
  })();
</script>
