---
import { FiGlobe, FiActivity, FiZap, FiArrowRight, FiMapPin, FiTarget } from 'react-icons/fi';
import { localizedHref, type Locale } from '../../lib/content';

interface Props {
  ui: any;
  locale: Locale;
}
const { ui, locale } = Astro.props;
const r = ui.research ?? {};
const Icons: Record<string, any> = { FiGlobe, FiActivity, FiZap };
---

<section class="py-20 bg-gray-900 relative overflow-hidden">
  {/* subtle ambient red glow, on-brand */}
  <div class="absolute inset-0 z-0 pointer-events-none">
    <div class="absolute -top-24 left-1/4 w-[28rem] h-[28rem] bg-red-600/10 rounded-full blur-[120px]"></div>
    <div class="absolute -bottom-24 right-1/4 w-[28rem] h-[28rem] bg-red-500/5 rounded-full blur-[120px]"></div>
  </div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="text-center mb-14 reveal">
      <h2 class="title-gradient text-3xl md:text-4xl font-bold mb-5">{r.title}</h2>
      <div class="section-bar mx-auto bg-red-500"></div>
      <p class="mt-6 text-2xl md:text-3xl font-semibold bg-gradient-to-r from-red-400 to-red-600 bg-clip-text text-transparent max-w-3xl mx-auto">
        {r.lead}
      </p>
      <p class="mt-4 text-lg text-gray-300 max-w-2xl mx-auto">{r.intro}</p>
    </div>

    {/* 3 research pillars */}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto" data-stagger>
      {(r.pillars ?? []).map((p: any) => {
        const Icon = Icons[p.icon];
        return (
          <div class="bg-gray-800/70 backdrop-blur-sm rounded-xl p-7 border border-gray-700 hover:border-red-500/40 transition-all duration-200 hover:-translate-y-1 h-full">
            <div class="w-12 h-12 rounded-full bg-red-500/15 text-red-400 flex items-center justify-center mb-4">
              {Icon && <Icon size={24} />}
            </div>
            <h3 class="text-lg font-bold text-white mb-2">{p.title}</h3>
            <p class="text-gray-300 text-sm leading-relaxed">{p.desc}</p>
          </div>
        );
      })}
    </div>

    {/* Now + Goal highlight band */}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-5xl mx-auto mt-8 reveal">
      <div class="flex items-start gap-3 rounded-xl border border-red-500/20 bg-red-500/5 p-5">
        <FiMapPin className="text-red-400 shrink-0 mt-1" size={20} />
        <div>
          <div class="text-xs uppercase tracking-wider text-red-400 font-semibold mb-1">{r.nowLabel}</div>
          <p class="text-gray-200 text-sm leading-relaxed">{r.now}</p>
        </div>
      </div>
      <div class="flex items-start gap-3 rounded-xl border border-red-500/20 bg-red-500/5 p-5">
        <FiTarget className="text-red-400 shrink-0 mt-1" size={20} />
        <div>
          <div class="text-xs uppercase tracking-wider text-red-400 font-semibold mb-1">{r.goalLabel}</div>
          <p class="text-gray-200 text-sm leading-relaxed font-medium">{r.goal}</p>
        </div>
      </div>
    </div>

    {/* CTAs */}
    <div class="flex flex-wrap gap-4 justify-center mt-10 reveal">
      <a href={localizedHref('/publications', locale)} class="btn-primary inline-flex items-center gap-2">
        {r.ctaPublications} <FiArrowRight />
      </a>
      <a href={localizedHref('/contact', locale)} class="btn-outline inline-flex items-center gap-2">
        {r.ctaContact}
      </a>
    </div>
  </div>
</section>
