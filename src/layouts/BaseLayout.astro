---
import '../index.css';
import SEO from '../components/SEO.astro';

export interface Props {
  locale: 'fr' | 'en';
  pageType: string;
  path: string;
  title?: string;
  description?: string;
}
const { locale, pageType, path, title, description } = Astro.props;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <SEO locale={locale} pageType={pageType} path={path} title={title} description={description} />

    <link rel="icon" href="/assets/images/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/images/favicon.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#171717" />

    {/* Pre-paint theme (no flash): mirror ThemeContext — localStorage 'theme' else system pref */}
    <script is:inline>
      (function () {
        document.documentElement.classList.add('js'); // enables scroll-reveal only when JS is on
        try {
          var t = localStorage.getItem('theme');
          var dark = t ? t === 'dark' : window.matchMedia('(prefers-color-scheme: dark)').matches;
          document.documentElement.classList.toggle('dark', dark);
        } catch (e) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <style is:global>
      /* Scroll reveal — content stays visible without JS (good for SEO/no-JS) */
      .reveal { transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
      html.js .reveal { opacity: 0; transform: translateY(24px); }
      html.js .reveal.in-view { opacity: 1; transform: none; }
      @media (prefers-reduced-motion: reduce) {
        html.js .reveal { opacity: 1; transform: none; transition: none; }
      }
    </style>
  </head>
  <body>
    <div id="root">
      <slot />
    </div>

    {/* Scroll reveal: reveal elements as they enter the viewport (with optional stagger) */}
    <script is:inline>
      (function () {
        var els = document.querySelectorAll('.reveal');
        if (!('IntersectionObserver' in window) || !els.length) {
          els.forEach(function (e) { e.classList.add('in-view'); });
          return;
        }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              var el = entry.target;
              var delay = el.getAttribute('data-reveal-delay');
              if (delay) el.style.transitionDelay = delay + 'ms';
              el.classList.add('in-view');
              io.unobserve(el);
            }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
        els.forEach(function (e) { io.observe(e); });
      })();
    </script>

    {/* Global theme toggle: any [data-theme-toggle] flips .dark + persists (mirrors ThemeContext) */}
    <script is:inline>
      document.addEventListener('click', function (e) {
        var t = e.target.closest && e.target.closest('[data-theme-toggle]');
        if (!t) return;
        var isDark = document.documentElement.classList.toggle('dark');
        try { localStorage.setItem('theme', isDark ? 'dark' : 'light'); } catch (err) {}
        var meta = document.querySelector('meta[name="theme-color"]');
        if (meta) meta.setAttribute('content', isDark ? '#171717' : '#ffffff');
      });
    </script>
  </body>
</html>
