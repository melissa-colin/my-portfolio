---
import '../index.css';
import SEO from '../components/SEO.astro';

export interface Props {
  locale: 'fr' | 'en';
  pageType: string;
  path: string;
  title?: string;
  description?: string;
}
const { locale, pageType, path, title, description } = Astro.props;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <SEO locale={locale} pageType={pageType} path={path} title={title} description={description} />

    <link rel="icon" href="/assets/images/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/images/favicon.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#171717" />

    {/* Pre-paint theme (no flash): mirror ThemeContext — localStorage 'theme' else system pref */}
    <script is:inline>
      (function () {
        document.documentElement.classList.add('js'); // enables scroll-reveal only when JS is on
        try {
          var t = localStorage.getItem('theme');
          var dark = t ? t === 'dark' : window.matchMedia('(prefers-color-scheme: dark)').matches;
          document.documentElement.classList.toggle('dark', dark);
        } catch (e) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <style is:global>
      /* ===== Scroll reveal (below-the-fold) — content stays visible without JS ===== */
      .reveal { transition: opacity 0.9s ease-out, transform 0.9s ease-out; }
      html.js .reveal { opacity: 0; transform: translateY(28px); }
      html.js .reveal.in-view { opacity: 1; transform: none; }
      /* Staggered cascade for grid/list children (opacity-only -> no clash with hover transforms) */
      html.js [data-stagger] > * { opacity: 0; transition: opacity 0.7s ease-out; }
      html.js [data-stagger].in-view > * { opacity: 1; }

      /* ===== Load entrance (above-the-fold), mirrors the old framer-motion intros ===== */
      @keyframes aFadeUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: none; } }
      @keyframes aFade { from { opacity: 0; } to { opacity: 1; } }
      @keyframes aBar { from { opacity: 0; transform: scaleX(0); } to { opacity: 1; transform: scaleX(1); } }
      @keyframes aSlideDown { from { opacity: 0; transform: translateY(-40px); } to { opacity: 1; transform: none; } }
      @keyframes aTitleIn { from { opacity: 0; transform: translateY(22px) scale(0.94); } to { opacity: 1; transform: none; } }
      html.js .a-fade-up { animation: aFadeUp 0.9s cubic-bezier(0.16, 0.7, 0.2, 1) both; }
      html.js .a-fade { animation: aFade 1.1s ease-out both; }
      html.js .a-bar { animation: aBar 1s cubic-bezier(0.16, 0.7, 0.2, 1) both; transform-origin: center; }
      html.js .a-slidedown { animation: aSlideDown 0.8s cubic-bezier(0.16, 0.7, 0.2, 1) both; }
      html.js .anim-title { animation: aTitleIn 0.9s cubic-bezier(0.16, 0.7, 0.2, 1) both; }
      /* page-level gentle fade (opacity only; per-element classes provide the movement) */
      html.js .page-enter { animation: aFade 0.7s ease-out both; }

      @media (prefers-reduced-motion: reduce) {
        html.js .reveal, html.js [data-stagger] > * { opacity: 1; transform: none; transition: none; }
        html.js .a-fade-up, html.js .a-fade, html.js .a-bar, html.js .a-slidedown,
        html.js .anim-title, html.js .page-enter { animation: none; }
      }
    </style>
  </head>
  <body>
    <div id="root">
      <slot />
    </div>

    {/* Scroll reveal: reveal elements as they enter the viewport (with optional stagger) */}
    <script is:inline>
      (function () {
        var els = document.querySelectorAll('.reveal, [data-stagger]');
        if (!('IntersectionObserver' in window) || !els.length) {
          els.forEach(function (e) { e.classList.add('in-view'); });
          return;
        }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (!entry.isIntersecting) return;
            var el = entry.target;
            if (el.hasAttribute('data-stagger')) {
              var kids = el.children;
              for (var i = 0; i < kids.length; i++) {
                kids[i].style.transitionDelay = ((i % 8) * 120) + 'ms';
              }
            } else {
              var delay = el.getAttribute('data-reveal-delay');
              if (delay) el.style.transitionDelay = delay + 'ms';
            }
            el.classList.add('in-view');
            io.unobserve(el);
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
        els.forEach(function (e) { io.observe(e); });
      })();
    </script>

    {/* Replay entrance animations when the page is restored from the back/forward cache (Firefox) */}
    <script is:inline>
      window.addEventListener('pageshow', function (e) {
        if (!e.persisted) return;
        var h = document.documentElement;
        h.classList.remove('js');
        void h.offsetWidth; // force reflow so the animations restart
        h.classList.add('js');
      });
    </script>

    {/* Global theme toggle: any [data-theme-toggle] flips .dark + persists (mirrors ThemeContext) */}
    <script is:inline>
      document.addEventListener('click', function (e) {
        var t = e.target.closest && e.target.closest('[data-theme-toggle]');
        if (!t) return;
        var isDark = document.documentElement.classList.toggle('dark');
        try { localStorage.setItem('theme', isDark ? 'dark' : 'light'); } catch (err) {}
        var meta = document.querySelector('meta[name="theme-color"]');
        if (meta) meta.setAttribute('content', isDark ? '#171717' : '#ffffff');
      });
    </script>
  </body>
</html>
